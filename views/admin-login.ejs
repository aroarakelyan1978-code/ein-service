<%- include('partials/header') %>

<section class="landing-simple admin-flat-page">
  <div class="container landing-simple-shell admin-flat-shell">
    <section class="landing-simple-intro admin-flat-intro">
      <h1>ITIN Admin | Internal Application Dashboard</h1>
      <p>Secure internal login for ETAX IDS application review and status management.</p>
    </section>

    <section class="landing-simple-box admin-flat-box admin-login-box">
      <h2>ADMIN LOGIN</h2>
      <p>Sign in to review submitted ITIN applications, update case statuses, and download prefilled official W-7 forms.</p>
      <form class="admin-flat-form" method="post" action="/admin/login">
        <% if (loginError) { %>
          <div class="inline-alert inline-alert-error"><%= loginError %></div>
        <% } %>
        <label class="admin-flat-field">
          <span>Email</span>
          <input type="email" name="email" required />
        </label>
        <label class="admin-flat-field">
          <span>Password</span>
          <input type="password" name="password" required />
        </label>
        <div class="admin-flat-action-row">
          <button type="submit" class="landing-flat-button">SIGN IN</button>
        </div>
      </form>
    </section>
  </div>
</section>

<%- include('partials/footer') %>
