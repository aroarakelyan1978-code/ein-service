<%
  const ctaOptions = [
    { value: 'new', label: 'Apply for a New ITIN' },
    { value: 'renewal', label: 'Renew an Existing ITIN' },
  ];
  const pricingItems = [
    {
      title: 'New ITIN Application Assistance',
      service: 'new-itin-application-assistance',
      applyHref: '/apply?type=new',
      copy: [
        'Guided help for first-time ITIN applicants who need Form W-7 preparation support, document checklist guidance, and internal order tracking.',
        'This option is designed for applicants who have never received an ITIN and need help preparing a new request with the correct supporting information.',
        'Use this option when you are starting a brand-new ITIN assistance request.',
      ],
    },
    {
      title: 'ITIN Renewal Assistance',
      service: 'itin-renewal-assistance',
      applyHref: '/apply?type=renewal',
      copy: [
        'Support for renewing an existing ITIN when a prior number has expired or needs to be reactivated for filing purposes.',
        'Our guided renewal intake is built for applicants who were previously issued an ITIN and now need to renew it before filing or claiming tax-related benefits.',
        'Use this option if the applicant already had an ITIN and now needs renewal assistance.',
      ],
    },
    {
      title: 'Spouse ITIN Assistance',
      service: 'new-itin-application-assistance',
      applyHref: '/apply?itinProfile=spouse',
      copy: [
        'Private preparation support for spouses listed on a U.S. federal tax return who are not eligible for a Social Security number.',
        'This category is commonly used when a spouse must be included on a tax filing but does not qualify for an SSN and needs ITIN preparation help instead.',
        'Choose this option when the ITIN request is for a spouse applicant.',
      ],
    },
    {
      title: 'Dependent ITIN Assistance',
      service: 'new-itin-application-assistance',
      applyHref: '/apply?itinProfile=dependent',
      copy: [
        'Guided application help for qualifying dependents who need an ITIN for tax filing or related IRS processing purposes.',
        'This option helps families prepare an ITIN request for a dependent who must be listed for filing, credit, or supporting tax documentation purposes.',
        'Choose this option when the ITIN request is for a dependent applicant.',
      ],
    },
    {
      title: 'Resident Alien Filing Support',
      service: 'form-w7-preparation-review',
      applyHref: '/apply?itinProfile=individual',
      copy: [
        'Assistance for resident aliens who need an ITIN to complete a U.S. federal tax filing and are not eligible for an SSN.',
        'This intake is intended for applicants who meet resident filing rules but still require an ITIN to move forward with the W-7 process and tax filing support.',
        'Use this option when the applicant is filing as a resident alien and needs ITIN preparation guidance.',
      ],
    },
    {
      title: 'Nonresident Alien Filing Support',
      service: 'form-w7-preparation-review',
      applyHref: '/apply?itinProfile=individual',
      copy: [
        'Preparation support for nonresident applicants who require an ITIN for U.S. federal return filing or related tax reporting.',
        'This option is intended for applicants who are filing as nonresident aliens and need guided help choosing the correct W-7 reason and supporting documents.',
        'Use this option when the applicant is not a resident for tax purposes and needs ITIN filing support.',
      ],
    },
    {
      title: 'Tax Treaty Benefit Cases',
      service: 'form-w7-preparation-review',
      applyHref: '/apply?itinProfile=treaty-other',
      copy: [
        'Help reviewing treaty-related details when an applicant needs an ITIN to claim a tax treaty benefit and complete the related W-7 reason.',
        'This category is for applicants who need extra guidance with treaty country details, treaty article references, and the corresponding W-7 explanation fields.',
        'Choose this option if the applicant needs ITIN assistance tied to a tax treaty benefit claim.',
      ],
    },
    {
      title: 'Student / Professor / Researcher Cases',
      service: 'form-w7-preparation-review',
      applyHref: '/apply?itinProfile=student-researcher',
      copy: [
        'Guided support for applicants filing under the student, professor, or researcher categories described in the Form W-7 instructions.',
        'This option is designed for applicants whose ITIN request falls under the education or research categories and may involve exception-based documentation review.',
        'Use this option when the applicant is filing as a student, professor, or researcher.',
      ],
    },
    {
      title: 'Form W-7 Review Service',
      service: 'form-w7-preparation-review',
      applyHref: '/apply',
      copy: [
        'A structured review of the information provided for completeness, common issues, and packet readiness before submission steps.',
        'This service is useful when the applicant already has basic information prepared but wants guided review support before moving forward with the final packet.',
        'Choose this option when you need a W-7 preparation review rather than a general question.',
      ],
    },
    {
      title: 'Document Checklist Guidance',
      service: 'document-checklist-guidance',
      applyHref: '/apply',
      copy: [
        'Help identifying the documents typically needed to establish identity and foreign status for an ITIN application packet.',
        'This option is for applicants who mainly need document guidance before starting or completing the rest of the intake.',
        'Use this option when you want help understanding which documents may be needed for ITIN preparation.',
      ],
    },
  ];
%>
<%- include('partials/header') %>

<section class="landing-simple">
  <div class="container landing-simple-shell">
    <section class="landing-simple-intro">
      <h1>ITIN Number | Individual Taxpayer Identification Services</h1>
      <p>Apply for Individual Taxpayer Identification Number | Apply for ITIN</p>
    </section>

    <section class="landing-simple-box landing-simple-apply">
      <h2>APPLY FOR ITIN - W-7 HELP</h2>
      <div class="landing-simple-apply-row">
        <p>Get guided help with your Individual Taxpayer Identification Number application through our secure and simple step-by-step preparation process.</p>
        <a class="landing-flat-button" href="/apply">APPLY FOR ITIN</a>
      </div>
    </section>

    <section class="landing-services-layout">
      <div class="landing-simple-box landing-services-box">
        <h2>ITIN Assistance - Services</h2>
        <p class="landing-services-intro">Select a service below to open a short request form. When it is submitted, our team receives it by email.</p>
        <ul class="landing-service-list">
          <li><a href="/service-request?service=new-itin-application-assistance">New ITIN Application Assistance</a></li>
          <li><a href="/service-request?service=itin-renewal-assistance">ITIN Renewal Assistance</a></li>
          <li><a href="/service-request?service=form-w7-preparation-review">Form W-7 Preparation Review</a></li>
          <li><a href="/service-request?service=existing-application-support">Track Existing Application</a></li>
          <li><a href="/service-request?service=pricing-and-service-questions">Service Pricing &amp; Fee Disclosure</a></li>
        </ul>
      </div>
      <div class="landing-service-mark" aria-hidden="true">
        <img src="/icon-building.png" alt="" />
      </div>
    </section>

    <section class="landing-section-block landing-type-section" id="pricing">
      <h2>Common ITIN Application Types</h2>
      <div class="landing-type-list">
        <% pricingItems.forEach(function(item) { %>
          <details class="landing-type-row">
            <summary>
              <span><%= item.title %></span>
              <strong>?</strong>
            </summary>
            <div class="landing-type-body">
              <% item.copy.forEach(function(copyItem) { %>
                <p><%= copyItem %></p>
              <% }) %>
              <a class="landing-type-link" href="<%= item.applyHref %>">Start Application</a>
            </div>
          </details>
        <% }) %>
      </div>
    </section>

    <section class="landing-final-cta">
      <h2>Ready to apply for ITIN?</h2>
      <div class="landing-final-card">
        <h3>ITIN | Individual Taxpayer Identification Number</h3>
        <p>Get guided help with your Individual Taxpayer Identification Number (ITIN) application online today.</p>
        <form class="landing-final-form" action="/apply" method="get">
          <select class="landing-final-select" name="type" aria-label="Select application type" required>
            <option value="" selected disabled>Select Application Type</option>
            <% ctaOptions.forEach(function(option) { %>
              <option value="<%= option.value %>"><%= option.label %></option>
            <% }) %>
          </select>
          <button class="landing-flat-button landing-final-button" type="submit">APPLY NOW</button>
        </form>
      </div>
      <div class="landing-final-mark" aria-hidden="true">
        <img src="/icon-building.png" alt="" />
      </div>
      <p class="landing-final-support">Representatives are available Monday through Friday from 9 AM – 5 PM PST.</p>
      <p class="landing-final-contact">E-mail us at <a href="mailto:<%= site.supportEmail %>"><%= site.supportEmail %></a> or visit <a href="/contact">Contact Us page</a>.</p>
    </section>
  </div>
</section>

<%- include('partials/footer') %>
